<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ClaudeCodeMDI.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />

        <!-- Apple-style Toolbar Button -->
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.85" />
        </Style>
        <Style Selector="Button.toolbar:pointerover">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.toolbar:pressed">
            <Setter Property="Background" Value="#10FFFFFF" />
        </Style>

        <!-- Apple-style Icon Button -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.icon-btn:pressed">
            <Setter Property="Background" Value="#10FFFFFF" />
        </Style>

        <!-- Apple-style Primary Button (system blue) -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#007AFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#0A84FF" />
        </Style>
        <Style Selector="Button.primary:pressed">
            <Setter Property="Background" Value="#0064D2" />
        </Style>
        <Style Selector="Button.primary:disabled">
            <Setter Property="Background" Value="#1A3A3C" />
            <Setter Property="Foreground" Value="#48484A" />
        </Style>

        <!-- Apple-style TextBox -->
        <Style Selector="TextBox.modern">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3A3A3C" />
            <Setter Property="Background" Value="#1C1C1E" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox.modern:focus">
            <Setter Property="BorderBrush" Value="#007AFF" />
        </Style>

        <!-- Apple-style ComboBox -->
        <Style Selector="ComboBox.modern">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3A3A3C" />
            <Setter Property="Background" Value="#1C1C1E" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Apple-style ToggleButton -->
        <Style Selector="ToggleButton.toolbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.85" />
        </Style>
        <Style Selector="ToggleButton.toolbar:pointerover">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ToggleButton.toolbar:checked">
            <Setter Property="Background" Value="#18FFFFFF" />
        </Style>

        <!-- Tab styling -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="14,7" />
        </Style>

        <!-- Apple-style Activity Bar Button (sidebar icons) -->
        <Style Selector="Button.activity-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.45" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="4,1" />
        </Style>
        <Style Selector="Button.activity-btn:pointerover">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.activity-btn.active">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Background" Value="#18FFFFFF" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <!-- Apple Dark Mode palette -->
        <SolidColorBrush x:Key="ToolBarBg" Color="#2C2C2E" />
        <SolidColorBrush x:Key="StatusBarBg" Color="#1C1C1E" />
        <SolidColorBrush x:Key="SurfaceBg" Color="#000000" />
        <SolidColorBrush x:Key="AccentBlue" Color="#007AFF" />
        <SolidColorBrush x:Key="AccentGreen" Color="#30D158" />
        <SolidColorBrush x:Key="SubtleText" Color="#98989D" />
        <SolidColorBrush x:Key="DividerColor" Color="#38383A" />
        <SolidColorBrush x:Key="ActivityBarBg" Color="#1C1C1E" />
        <SolidColorBrush x:Key="SidePanelBg" Color="#2C2C2E" />
    </Application.Resources>
</Application>
