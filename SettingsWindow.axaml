<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeCodeMDI.SettingsWindow"
        Title="Settings"
        Width="420" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource SurfaceBg}">

    <DockPanel Margin="28">
        <!-- Title -->
        <TextBlock DockPanel.Dock="Top" Text="Console Settings"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,24" />

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="10" Margin="0,24,0,0">
            <Button Content="Cancel" Classes="toolbar" Click="OnCancel"
                    Padding="20,7" />
            <Button Content="OK" Classes="primary" Click="OnOk"
                    Padding="20,7" />
        </StackPanel>

        <!-- Settings form -->
        <StackPanel Spacing="20">
            <!-- Font Family -->
            <StackPanel Spacing="6">
                <TextBlock Text="Font Family" FontSize="13"
                           Foreground="{DynamicResource SubtleText}" />
                <ComboBox x:Name="CmbFontFamily" Classes="modern"
                          HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Font Size -->
            <StackPanel Spacing="6">
                <TextBlock Text="Font Size" FontSize="13"
                           Foreground="{DynamicResource SubtleText}" />
                <NumericUpDown x:Name="NumFontSize"
                               Minimum="8" Maximum="32" Increment="1"
                               FormatString="0"
                               HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Theme -->
            <StackPanel Spacing="6">
                <TextBlock Text="Theme" FontSize="13"
                           Foreground="{DynamicResource SubtleText}" />
                <ComboBox x:Name="CmbTheme" Classes="modern"
                          HorizontalAlignment="Stretch" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
