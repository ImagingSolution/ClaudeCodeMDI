<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svc="clr-namespace:ClaudeCodeMDI.Services"
        xmlns:local="clr-namespace:ClaudeCodeMDI"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="ClaudeCodeMDI.MainWindow"
        Title="Claude Code MDI"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Icon="avares://ClaudeCodeMDI/icon.ico"
        Background="{DynamicResource SurfaceBg}">

    <Window.Styles>
        <Style Selector="TextBox.snippet-text">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="TextBox.snippet-text:pointerover">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="TextBox.snippet-text:focus">
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Apple-style Toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolBarBg}"
                Padding="16,10,16,5" BorderBrush="{DynamicResource DividerColor}"
                BorderThickness="0,0,0,0.5">
            <StackPanel Spacing="10">
                <!-- Row 1: Project + Row 2: Session -->
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="56,*,Auto">
                    <!-- Row 0: Project -->
                    <TextBlock x:Name="LblProject" Grid.Row="0" Grid.Column="0"
                               Text="Project" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource SubtleText}"
                               FontWeight="Normal" />

                    <ComboBox x:Name="CmbProjectFolder" Grid.Row="0" Grid.Column="1"
                              Classes="modern"
                              IsEditable="True"
                              PlaceholderText="Select project folder..."
                              VerticalAlignment="Center"
                              HorizontalAlignment="Stretch"
                              Margin="10,0"
                              SelectionChanged="OnProjectFolderSelectionChanged"
                              KeyDown="OnProjectFolderKeyDown" />

                    <Button x:Name="BtnNewClaude" Grid.Row="0" Grid.Column="2"
                            Classes="primary"
                            ToolTip.Tip="Open new Claude Code session"
                            Click="OnNewClaude"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                        <TextBlock x:Name="LblNewClaude" Text="New Claude"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>

                    <!-- Row 1: Session -->
                    <TextBlock x:Name="LblSession" Grid.Row="1" Grid.Column="0"
                               Text="Session" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource SubtleText}"
                               FontWeight="Normal" Margin="0,3,0,0" />

                    <ComboBox x:Name="CmbSessions" Grid.Row="1" Grid.Column="1"
                              Classes="modern"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Stretch"
                              Margin="10,3,10,0"
                              PlaceholderText="Select a session to resume..."
                              SelectionChanged="OnSessionSelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="svc:SessionInfo">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Background="#18007AFF" CornerRadius="6" Padding="8,3">
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}"
                                                   FontSize="11" Foreground="#64A5FF"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding Summary}" FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               MaxWidth="400" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button x:Name="BtnResumeSession" Grid.Row="1" Grid.Column="2"
                            Classes="primary"
                            ToolTip.Tip="Resume selected session"
                            Click="OnResumeSession"
                            IsEnabled="False"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,3,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M8 5V19L19 12L8 5Z" Width="11" Height="11"
                                      Foreground="White" />
                            <TextBlock x:Name="LblResume" Text="Resume" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Apple-style Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBg}"
                Padding="16,6" BorderBrush="{DynamicResource DividerColor}"
                BorderThickness="0,0.5,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <!-- Git repo icon + name -->
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <PathIcon Data="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"
                              Width="14" Height="14" Foreground="{DynamicResource SubtleText}" />
                    <TextBlock x:Name="StatusRepoName" Text=""
                               Foreground="{DynamicResource SubtleText}" FontSize="11"
                               VerticalAlignment="Center" Cursor="Hand"
                               DoubleTapped="OnRepoNameDoubleTapped" />
                </StackPanel>
                <!-- Git branch icon + name -->
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <PathIcon Data="M6 3C4.34 3 3 4.34 3 6C3 7.31 3.84 8.41 5 8.83V15.17C3.84 15.59 3 16.69 3 18C3 19.66 4.34 21 6 21C7.66 21 9 19.66 9 18C9 16.69 8.16 15.59 7 15.17V8.83C8.16 8.41 9 7.31 9 6C9 4.34 7.66 3 6 3ZM6 5C6.55 5 7 5.45 7 6C7 6.55 6.55 7 6 7C5.45 7 5 6.55 5 6C5 5.45 5.45 5 6 5ZM6 17C6.55 17 7 17.45 7 18C7 18.55 6.55 19 6 19C5.45 19 5 18.55 5 18C5 17.45 5.45 17 6 17ZM18 3C16.34 3 15 4.34 15 6C15 7.31 15.84 8.41 17 8.83V12C17 13.1 16.1 14 15 14H13V12L9 16L13 20V18H15C18.31 18 19 15.31 19 12V8.83C20.16 8.41 21 7.31 21 6C21 4.34 19.66 3 18 3ZM18 5C18.55 5 19 5.45 19 6C19 6.55 18.55 7 18 7C17.45 7 17 6.55 17 6C17 5.45 17.45 5 18 5Z"
                              Width="14" Height="14" Foreground="{DynamicResource SubtleText}" />
                    <TextBlock x:Name="StatusBranchName" Text=""
                               Foreground="{DynamicResource SubtleText}" FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Area: ActivityBar | SidePanel | Splitter | RightArea(WindowStrip + MDI) -->
        <Grid x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Activity Bar (full height) -->
            <Border Grid.Column="0" Background="{DynamicResource ActivityBarBg}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0.5,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,8">
                        <Button x:Name="BtnActivityExplorer" Classes="activity-btn"
                                ToolTip.Tip="Explorer (Ctrl+Shift+E)"
                                Click="OnActivityExplorer">
                            <PathIcon Data="M17.5 0H8.5L7 1.5V6H2.5L1 7.5V22.57L2.5 24H13.5L15 22.57V18H19.5L21 16.5V3.5L17.5 0ZM13.5 22.57H2.5V7.5H7V16.5L8.5 18H13.5V22.57ZM19.5 16.5H8.5V1.5H14.5V5.5H19.5V16.5ZM15.5 1.5L19.5 4.5H15.5V1.5Z"
                                      Width="20" Height="20" />
                        </Button>
                        <Button x:Name="BtnActivitySnippets" Classes="activity-btn"
                                ToolTip.Tip="Snippets"
                                Click="OnActivitySnippets">
                            <PathIcon Data="M4 2H14L20 8V22H4V2ZM6 4V20H18V9H13V4H6ZM7 12H17V14H7V12ZM7 16H14V18H7V16Z"
                                      Width="20" Height="20" />
                        </Button>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom"
                                Spacing="2" Margin="0,8">
                        <Button x:Name="BtnActivityModeSwitch" Classes="activity-btn"
                                ToolTip.Tip="Switch Mode (Shift+Tab)"
                                Click="OnActivityModeSwitch">
                            <PathIcon Data="M12 4V1L8 5L12 9V6C15.31 6 18 8.69 18 12C18 13.01 17.75 13.97 17.3 14.8L18.76 16.26C19.54 15.03 20 13.57 20 12C20 7.58 16.42 4 12 4ZM12 18C8.69 18 6 15.31 6 12C6 10.99 6.25 10.03 6.7 9.2L5.24 7.74C4.46 8.97 4 10.43 4 12C4 16.42 7.58 20 12 20V23L16 19L12 15V18Z"
                                      Width="20" Height="20" />
                        </Button>
                        <Button x:Name="BtnActivityCompact" Classes="activity-btn"
                                ToolTip.Tip="Compact (/compact)"
                                Click="OnActivityCompact">
                            <PathIcon Data="M4 1H20V3H4Z M6 4L18 8L6 12L12 12L22 8L12 4Z M2 12L14 16L2 20L8 20L18 16L8 12Z M4 21H20V23H4Z M10 3H14L12 5Z M10 21L12 19L14 21Z"
                                      Width="22" Height="22" />
                        </Button>
                        <Button x:Name="BtnActivitySettings" Classes="activity-btn"
                                ToolTip.Tip="Settings"
                                Click="OnActivitySettings">
                            <PathIcon Data="M12 15.5A3.5 3.5 0 0 1 8.5 12A3.5 3.5 0 0 1 12 8.5A3.5 3.5 0 0 1 15.5 12A3.5 3.5 0 0 1 12 15.5M19.43 12.97C19.47 12.65 19.5 12.33 19.5 12C19.5 11.67 19.47 11.34 19.43 11L21.54 9.37C21.73 9.22 21.78 8.95 21.66 8.73L19.66 5.27C19.54 5.05 19.27 4.96 19.05 5.05L16.56 6.05C16.04 5.66 15.5 5.32 14.87 5.07L14.5 2.42C14.46 2.18 14.25 2 14 2H10C9.75 2 9.54 2.18 9.5 2.42L9.13 5.07C8.5 5.32 7.96 5.66 7.44 6.05L4.95 5.05C4.73 4.96 4.46 5.05 4.34 5.27L2.34 8.73C2.21 8.95 2.27 9.22 2.46 9.37L4.57 11C4.53 11.34 4.5 11.67 4.5 12C4.5 12.33 4.53 12.65 4.57 12.97L2.46 14.63C2.27 14.78 2.21 15.05 2.34 15.27L4.34 18.73C4.46 18.95 4.73 19.04 4.95 18.95L7.44 17.94C7.96 18.34 8.5 18.68 9.13 18.93L9.5 21.58C9.54 21.82 9.75 22 10 22H14C14.25 22 14.46 21.82 14.5 21.58L14.87 18.93C15.5 18.67 16.04 18.34 16.56 17.94L19.05 18.95C19.27 19.04 19.54 18.95 19.66 18.73L21.66 15.27C21.78 15.05 21.73 14.78 21.54 14.63L19.43 12.97Z"
                                      Width="20" Height="20" />
                        </Button>
                    </StackPanel>
                    <Border />
                </DockPanel>
            </Border>

            <!-- Side Panel (full height, next to Activity Bar) -->
            <Border Grid.Column="1" x:Name="SidePanel" Background="{DynamicResource SidePanelBg}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0.5,0"
                    ClipToBounds="True">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="14,10"
                            BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,0.5">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock x:Name="SidePanelTitle" Text="EXPLORER"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SubtleText}"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center" />
                            <Button x:Name="BtnBrowseFolder" Grid.Column="1"
                                    Classes="icon-btn"
                                    ToolTip.Tip="Browse folder..."
                                    Click="OnBrowseFolder"
                                    Padding="4" Margin="0,-4,0,-4">
                                <PathIcon Data="M2 6C2 4.89543 2.89543 4 4 4H9L11 6H18C19.1046 6 20 6.89543 20 8V16C20 17.1046 19.1046 18 18 18H4C2.89543 18 2 17.1046 2 16V6Z"
                                          Width="13" Height="13" />
                            </Button>
                        </Grid>
                    </Border>

                    <Grid>
                        <!-- Explorer Panel -->
                        <DockPanel x:Name="ExplorerPanel">
                            <TreeView x:Name="FileTree"
                                      Background="Transparent"
                                      Margin="0,4"
                                      DoubleTapped="OnTreeItemDoubleTapped">
                                <TreeView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem x:Name="MenuTreeOpen" Header="Open" Click="OnTreeOpenDefault">
                                            <MenuItem.Icon>
                                                <PathIcon Data="M14 2H6C4.9 2 4 2.9 4 4V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V8L14 2ZM18 20H6V4H13V9H18V20Z"
                                                          Width="14" Height="14" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem x:Name="MenuTreeOpenWith" Header="Open with..." Click="OnTreeOpenWith">
                                            <MenuItem.Icon>
                                                <PathIcon Data="M19 19H5V5H12V3H5C3.89 3 3 3.9 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V12H19V19ZM14 3V5H17.59L7.76 14.83L9.17 16.24L19 6.41V10H21V3H14Z"
                                                          Width="14" Height="14" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem x:Name="MenuTreeShowInExplorer" Header="Show in Explorer" Click="OnTreeShowInExplorer">
                                            <MenuItem.Icon>
                                                <PathIcon Data="M2 6C2 4.89543 2.89543 4 4 4H9L11 6H18C19.1046 6 20 6.89543 20 8V16C20 17.1046 19.1046 18 18 18H4C2.89543 18 2 17.1046 2 16V6Z"
                                                          Width="14" Height="14" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem x:Name="MenuTreeCopyPath" Header="Copy Path" Click="OnTreeCopyPath">
                                            <MenuItem.Icon>
                                                <PathIcon Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1ZM19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5ZM19 21H8V7H19V21Z"
                                                          Width="14" Height="14" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </TreeView.ContextMenu>
                                <TreeView.Styles>
                                    <Style Selector="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.Styles>
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate x:DataType="local:FileTreeNode"
                                                      ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                    Background="Transparent">
                                            <PathIcon Data="{Binding IconData}" Width="14" Height="14"
                                                      Foreground="{Binding IconColor}" />
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </DockPanel>

                        <!-- Settings Panel -->
                        <ScrollViewer x:Name="SettingsPanel" IsVisible="False"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="20" Margin="14,16">
                                <Border BorderBrush="{DynamicResource SubtleText}" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8">
                                    <StackPanel Spacing="14">
                                        <TextBlock x:Name="LblConsoleSettings" Text="Console Settings" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SubtleText}" />
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="LblLanguage" Text="Language" FontSize="13"
                                                       Foreground="{DynamicResource SubtleText}" />
                                            <ComboBox x:Name="CmbSettingsLanguage" Classes="modern"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="LblFontFamily" Text="Font Family" FontSize="13"
                                                       Foreground="{DynamicResource SubtleText}" />
                                            <ComboBox x:Name="CmbSettingsFontFamily" Classes="modern"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="LblFontSize" Text="Font Size" FontSize="13"
                                                       Foreground="{DynamicResource SubtleText}" />
                                            <NumericUpDown x:Name="NumSettingsFontSize"
                                                           Minimum="8" Maximum="32" Increment="1"
                                                           FormatString="0"
                                                           HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                        <Button x:Name="BtnApplySettings" Classes="primary"
                                                HorizontalAlignment="Stretch"
                                                Click="OnApplySettings"
                                                Margin="0,4,0,0">
                                            <TextBlock x:Name="LblApplySettings" Text="Apply"
                                                       HorizontalAlignment="Center" />
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <StackPanel Spacing="6" Margin="0,16,0,0">
                                    <TextBlock x:Name="LblInitialPrompt" Text="Initial Prompt" FontSize="13"
                                               Foreground="{DynamicResource SubtleText}" />
                                    <TextBox x:Name="TxtInitialPrompt"
                                             HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <Button x:Name="BtnOpenClaudeFolder" Classes="primary"
                                        HorizontalAlignment="Stretch"
                                        Click="OnOpenClaudeFolder"
                                        Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                HorizontalAlignment="Center">
                                        <PathIcon Data="M2 6C2 4.89543 2.89543 4 4 4H9L11 6H18C19.1046 6 20 6.89543 20 8V16C20 17.1046 19.1046 18 18 18H4C2.89543 18 2 17.1046 2 16V6Z"
                                                  Width="12" Height="12" Foreground="White" />
                                        <TextBlock x:Name="LblOpenClaudeFolder" Text="Open .claude Folder" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <CheckBox x:Name="ChkShowWelcomePage" Content="Show Welcome Page"
                                          Margin="0,16,0,0"
                                          IsCheckedChanged="OnShowWelcomePageChanged" />
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Snippets Panel -->
                        <DockPanel x:Name="SnippetsPanel" IsVisible="False">
                            <Button x:Name="BtnAddSnippet" DockPanel.Dock="Bottom"
                                    Classes="primary" HorizontalAlignment="Stretch"
                                    Margin="10,8" Click="OnAddSnippet">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            HorizontalAlignment="Center">
                                    <PathIcon Data="M12 4V20M4 12H20" Width="12" Height="12"
                                              Foreground="White" />
                                    <TextBlock x:Name="LblAddSnippet" Text="Add Snippet" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="SnippetsList" Spacing="3"
                                            Margin="5,8" />
                            </ScrollViewer>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="2" x:Name="PanelSplitter"
                          Width="4" Background="Transparent"
                          IsVisible="False" />

            <!-- Right Area: WindowStrip (top) + MDI (fill) -->
            <DockPanel Grid.Column="3">
                <!-- Horizontal Window Strip -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource ToolBarBg}" Padding="6,4"
                        BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,0.5">
                    <Grid ColumnDefinitions="*,Auto">
                        <ScrollViewer Grid.Column="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="WindowStrip" Orientation="Horizontal" Spacing="4" />
                        </ScrollViewer>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2"
                                    Margin="8,0,0,0">
                            <Border Width="1" Background="{DynamicResource DividerColor}" Margin="0,4" />
                            <Button x:Name="BtnLayoutTile" Classes="icon-btn"
                                    ToolTip.Tip="Tile windows"
                                    Click="OnLayoutTile">
                                <PathIcon Data="M3 3H10V10H3ZM14 3H21V10H14ZM3 14H10V21H3ZM14 14H21V21H14Z"
                                          Width="14" Height="14" />
                            </Button>
                            <Button x:Name="BtnLayoutCascade" Classes="icon-btn"
                                    ToolTip.Tip="Cascade windows"
                                    Click="OnLayoutCascade">
                                <PathIcon Data="M2 2H14V14H2ZM6 6H18V18H6ZM10 10H22V22H10Z"
                                          Width="14" Height="14" />
                            </Button>
                            <Button x:Name="BtnLayoutMaximize" Classes="icon-btn"
                                    ToolTip.Tip="Full view"
                                    Click="OnLayoutMaximize">
                                <PathIcon Data="M3 3H21V21H3ZM5 5V19H19V5Z"
                                          Width="14" Height="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MDI Container -->
                <Canvas x:Name="MdiContainer"
                        Background="Transparent" ClipToBounds="True" />
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
